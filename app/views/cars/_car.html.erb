<div id="<%= dom_id car %>" class="col-sm-3 mb-3">
  <div  class="card mb-3">
    <% if car.image.attached? %>
        <%= image_tag car.image.variant(resize_to_fill: [400, 400]), class: "card-img-top img-cover",  style: "height: 200px; object-fit: cover;", alt: car.model %>
      <% end %>

    <div class="card-body">
      <h5 class="card-title">
        <%= car.model %> <small class="text-muted">(<%= car.year %>)</small>
      </h5>

      <p class="card-text mb-1">
        <strong>Trans:</strong> <%= car.formatted_transmission %><br>
        <strong>Cond:</strong> <%= car.formatted_condition %><br>
        <strong>Kms:</strong> <%= car.formatted_mileage %><br>
        <strong>Price:</strong> <span id="car_<%= car.id %>_price"><%= render "cars/price", car: car %></span><br>
        <strong>Brand:</strong> <%= car.brand.name if car.brand %>
      </p>

      
      <%= link_to t("actions.show"), car_path(car), data: { turbo_frame: "car_details" }, class: "btn btn-sm btn-outline-primary mt-2" %>

      <%= link_to t("actions.edit"), edit_car_path(car), data: { turbo_stream: true }, class: "btn btn-sm btn-outline-primary mt-2" %>
      <%= button_to t("actions.delete"), car_path(car), 
                    method: :delete, 
                    form: { data: { turbo_confirm: t("actions.confirm_delete") } }, 
                    class: "btn btn-sm btn-outline-danger mt-2" %>

    </div>
  </div>
</div>
